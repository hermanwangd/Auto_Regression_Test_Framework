#!/usr/bin/env sh
set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
MAIN_CLASS="com.specdriven.regression.RegressionApplication"

if [ ! -d "$ROOT_DIR/target/classes" ]; then
  "$ROOT_DIR/mvnw" -q -DskipTests compile >/dev/null
fi

if [ ! -f "$ROOT_DIR/target/runtime-classpath.txt" ] || [ "$ROOT_DIR/pom.xml" -nt "$ROOT_DIR/target/runtime-classpath.txt" ]; then
  "$ROOT_DIR/mvnw" -q -DincludeScope=runtime dependency:build-classpath -Dmdep.outputFile=target/runtime-classpath.txt >/dev/null
fi

if [ -d "$ROOT_DIR/target/classes" ]; then
  exec java -cp "$ROOT_DIR/target/classes:$(cat "$ROOT_DIR/target/runtime-classpath.txt")" "$MAIN_CLASS" "$@"
fi

JAR=$(find "$ROOT_DIR/target" -maxdepth 1 -type f -name 'spec-driven-auto-regression-*.jar' ! -name '*.original' 2>/dev/null | sort | head -n 1 || true)
if [ -n "$JAR" ] && [ -f "$JAR" ]; then
  exec java -jar "$JAR" "$@"
fi

echo "Unable to locate compiled classes or runnable jar. Run ./mvnw -q -DskipTests compile first." >&2
exit 2
