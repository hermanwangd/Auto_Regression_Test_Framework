{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["id", "status", "items"],
  "properties": {
    "id": { "type": "string" },
    "status": { "const": "OK" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"]
      }
    }
  }
}
